# Copy to android/keystore.properties (gitignored) and fill in.
# Generate the keystore with:
#   keytool -genkey -v -keystore myvitals-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias myvitals
#
# Keep myvitals-release.jks OUTSIDE the repo (e.g. in ~/.android-keys/),
# or somewhere covered by .gitignore. Lose this key and you cannot publish updates
# that install over previous versions.

storeFile=/absolute/path/to/myvitals-release.jks
storePassword=
keyAlias=myvitals
keyPassword=
