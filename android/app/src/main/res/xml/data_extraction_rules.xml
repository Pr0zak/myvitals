<?xml version="1.0" encoding="utf-8"?>
<!-- Disable cloud + device-transfer backup of app data (it holds the bearer token). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
    </device-transfer>
</data-extraction-rules>
