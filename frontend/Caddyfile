:80 {
    root * /srv
    encode gzip

    # Proxy API calls to the FastAPI backend (strip /api prefix)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:8000
    }

    # OAuth flows (Strava etc.) — pass through with original path so the
    # callback URL the user registers matches what Strava sees.
    handle /auth/* {
        reverse_proxy backend:8000
    }

    # Exercise icon thumbnails (StaticFiles mount on backend)
    handle /exercises/img/* {
        reverse_proxy backend:8000
    }

    # Hashed build assets are content-addressed and immutable — cache hard.
    handle /assets/* {
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # SPA fallback. index.html must NOT be cached, or a browser holding a
    # stale index keeps requesting old (now-404) chunk hashes and deep-links
    # to newly-added routes render blank. no-cache forces revalidation so a
    # fresh deploy is picked up on the next navigation.
    handle {
        header Cache-Control "no-cache"
        try_files {path} /index.html
        file_server
    }
}
