<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: the myvitals "vitality" tri-ring — sleep
     (magenta) / move (lime) / recovery (cyan), the same trio the Today home
     draws. The 108x108 viewport leaves an 18dp margin; the rings live inside
     the 72x72 safe zone (outer r=36 → spans 18..90). Matches the dashboard
     AppLogo + favicon. Strokes use trimPathEnd to open each ring. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-90">
        <!-- Outer ring — sleep (magenta) -->
        <path
            android:strokeColor="#FF3AD8"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:trimPathStart="0"
            android:trimPathEnd="0.76"
            android:pathData="M54,18 A36,36 0 1 1 53.99,18" />
        <!-- Middle ring — move (lime) -->
        <path
            android:strokeColor="#5DFF3B"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:trimPathStart="0"
            android:trimPathEnd="0.70"
            android:pathData="M54,29 A25,25 0 1 1 53.99,29" />
        <!-- Inner ring — recovery (cyan) -->
        <path
            android:strokeColor="#28E6FF"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:trimPathStart="0"
            android:trimPathEnd="0.82"
            android:pathData="M54,40 A14,14 0 1 1 53.99,40" />
    </group>
</vector>
