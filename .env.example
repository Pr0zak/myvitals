# --- database ---
POSTGRES_USER=myvitals
POSTGRES_PASSWORD=changeme
POSTGRES_DB=myvitals
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- image source (GHCR) ---
# Lowercase GitHub owner. Override only if you fork.
GHCR_OWNER=pr0zak
# Image tag to run. "latest" tracks the newest release; pin to "0.1.0" etc. for stability.
BACKEND_TAG=latest
FRONTEND_TAG=latest

# --- backend ---
# bearer token the Android app must present on POST /ingest/*
INGEST_TOKEN=replace-with-long-random-string
# bearer token for read endpoints used by the frontend
QUERY_TOKEN=replace-with-another-long-random-string
LOG_LEVEL=INFO
# IANA timezone — used for daily summary cutoffs (e.g. "America/New_York", "Europe/London")
TZ=UTC

# --- home assistant integration (optional) ---
# Local HA URL on your network (default mDNS hostname is homeassistant.local:8123)
HA_URL=
HA_TOKEN=
# Comma-separated entity IDs to poll every 5 min into env_readings.
# Examples:
#   sensor.bedroom_temperature,sensor.bedroom_humidity,binary_sensor.bedroom_presence
HA_ENTITIES=

# --- weather integration (optional) ---
OPENWEATHER_API_KEY=
HOME_LAT=
HOME_LON=
