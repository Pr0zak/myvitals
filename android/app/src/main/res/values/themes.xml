<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Window theme is just the brief frame Android shows before Compose paints.
      Use a dark NoActionBar so a light flash never appears on dark devices,
      then Compose's MyVitalsTheme drives all real colors.
    -->
    <style name="Theme.MyVitals" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
    </style>
</resources>
